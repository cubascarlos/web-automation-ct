pipeline {
    agent{
        docker{
            image 'maven:3.9.9-eclipse-temurin-21'
            args '-u root:root --entrypoint="" -t -v /Users/carlossalvatierra/jenkins_cache/.m2:/var/maven/.m2 -e MAVEN_CONFIG=/var/maven/.m2'
        }
    }

    //tools {
      //  maven 'maven-3.9.15'
        //jdk 'jdk-21'
    //}

    stages {
        stage('Checkout') {
            steps {
                deleteDir()
                //git branch: 'main', url: 'https://github.com/cubascarlos/web-automation-ct.git'
                sh 'mvn -B -Dmaven.repo.local=/var/maven/.m2 clean verify -Dcucumber.filter.tags="@NTLC-1" -Dheadless=true'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'mvn clean verify -Dcucumber.filter.tags="@NTLC-1"'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'target/**/*', allowEmptyArchive: true
            cucumber buildStatus: 'UNSTABLE',
                     fileIncludePattern: 'cucumber.json',
                     jsonReportDirectory: 'target/build'
        }
    }
}
